# OpenAI-compatible LLM endpoint for real agent reasoning.
# For 0G Compute, point these values at the 0G Compute/OpenAI-compatible endpoint when available.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace_me
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.8
LLM_MAX_TOKENS=500
# 0G Direct providers may enforce low RPM; keep speech calls spaced out for live demos.
LLM_MIN_REQUEST_INTERVAL_MS=6500

# Compute backend: mock | llm | llm-speech | 0g-speech | 0g-direct
# 0g-speech = 0G Compute speech generation + deterministic mock decisions.
# 0g-direct uses the provider OpenAI-compatible endpoint/key in ZEROG_COMPUTE_*.
# This keeps live gameplay stable while making agent language less templated.
COMPUTE_BACKEND=mock
ZEROG_COMPUTE_BASE_URL=https://compute-network-6.integratenetwork.work/v1/proxy
ZEROG_COMPUTE_API_KEY=replace_me
ZEROG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct
LLM_RESPONSE_FORMAT=1
# Optional local-only helper-script input. Prefer ZEROG_PRIVATE_KEY in local env/secret storage.
# WALLET_CONFIG_PATH=/absolute/path/to/local-wallet-config.json
# WALLET_LABEL=cornerstone

# Local LLM demo guard
DEMO_MAX_ROUNDS=3

# Telegram gameplay wrapper
TELEGRAM_BOT_TOKEN=replace_me
# Backward-compatible alias; prefer COMPUTE_BACKEND now.
USE_LLM=0

# Human action timeout fallback, prevents live demos from hanging forever.
HUMAN_ACTION_TIMEOUT_MS=120000

# Storage backend: local | 0g
STORAGE_BACKEND=local
ZEROG_NETWORK=testnet
ZEROG_STORAGE_MODE=turbo
ZEROG_PRIVATE_KEY=replace_me
# Optional; defaults exist for testnet/mainnet turbo/standard
ZEROG_EVM_RPC=https://evmrpc-testnet.0g.ai
ZEROG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# Optional real 0G Chain registry
CHAIN_BACKEND=mock              # mock | 0g
GAME_REGISTRY_ADDRESS=          # deployed GameRegistry.sol address on 0G Galileo; if empty, deployments/0g-galileo.GameRegistry.json is used when available

# Replay publishing behavior
UPDATE_LATEST_REPLAY=true
TELEGRAM_UPDATE_LATEST_REPLAY=0
